{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Rendobar",
  "theme": "mint",
  "colors": {
    "primary": "#34d399",
    "light": "#6ee7b7",
    "dark": "#10b981"
  },
  "background": {
    "color": {
      "dark": "#08090a",
      "light": "#ffffff"
    }
  },
  "logo": {
    "dark": "https://cdn.rendobar.com/assets/brand/logo-mark.svg",
    "light": "https://cdn.rendobar.com/assets/brand/logo-mark-black.svg",
    "href": "https://rendobar.com"
  },
  "favicon": "https://cdn.rendobar.com/assets/brand/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "quickstart",
              "authentication",
              "credits"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/raw-ffmpeg",
              "guides/webhooks",
              "guides/mcp-agents"
            ]
          },
          {
            "group": "CLI",
            "pages": [
              "cli/overview",
              "cli/installation",
              "cli/authentication",
              "cli/commands",
              "cli/ci-cd",
              "cli/troubleshooting"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/job-lifecycle",
              "concepts/credits"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "job-types/raw-ffmpeg"
            ]
          },
          {
            "group": "MCP",
            "pages": [
              "mcp/overview",
              "mcp/tools-reference"
            ]
          },
          {
            "group": "Support",
            "pages": [
              "support/faq",
              "support/limits",
              "support/errors"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "groups": [
          {
            "group": "Changelog",
            "pages": [
              "changelog/2026-03-20"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://app.rendobar.com",
          "icon": "gauge"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/rendobar",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://app.rendobar.com"
      },
      {
        "label": "Blog",
        "href": "https://rendobar.com/blog/"
      },
      {
        "label": "Pricing",
        "href": "https://rendobar.com/pricing/"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://app.rendobar.com"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/rendobar",
      "x": "https://x.com/rendobar",
      "discord": "https://discord.gg/rendobar"
    },
    "links": [
      {
        "title": "Product",
        "items": [
          {
            "label": "Pricing",
            "href": "https://rendobar.com/pricing/"
          },
          {
            "label": "Dashboard",
            "href": "https://app.rendobar.com"
          }
        ]
      },
      {
        "title": "Legal",
        "items": [
          {
            "label": "Terms of service",
            "href": "https://rendobar.com/terms/"
          },
          {
            "label": "Privacy policy",
            "href": "https://rendobar.com/privacy/"
          }
        ]
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "seo": {
    "indexing": "all",
    "metatags": {
      "og:type": "website",
      "og:site_name": "Rendobar",
      "og:locale": "en_US",
      "og:image": "https://rendobar.com/brand/og-default.png",
      "og:image:width": "1200",
      "og:image:height": "675",
      "og:image:alt": "Rendobar — Serverless media processing API",
      "og:image:type": "image/png",
      "twitter:card": "summary_large_image",
      "twitter:site": "@rendobar",
      "robots": "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    }
  },
  "search": {
    "prompt": "Search docs..."
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true
  }
}
